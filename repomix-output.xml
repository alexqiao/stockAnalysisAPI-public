            passed += 1
        else:
            print(f"❌ {test_name}")
            failed += 1
    
    print(f"\n📊 总计: {passed + failed} 个测试套件")
    print(f"✅ 通过: {passed}")
    print(f"❌ 失败: {failed}")
    
    if failed > 0:
        print("\n❗ 有测试失败，请查看上面的详细信息")
        return False
    
    print("\n🎉 所有测试通过!")
    
    # 6. 显示覆盖率报告
    if coverage_success and coverage_stdout:
        print("\n📊 代码覆盖率报告:")
        lines = coverage_stdout.split('\n')
        for line in lines:
            if 'TOTAL' in line or any(service in line for service in ['services/', 'app/']):
                print(line)
    
    return True

def main():
    """主函数"""
    try:
        success = run_test_suite()
        sys.exit(0 if success else 1)
    except KeyboardInterrupt:
        print("\n\n⚠️  测试被用户中断")
        sys.exit(1)
    except Exception as e:
        print(f"\n❌ 运行测试时发生错误: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
