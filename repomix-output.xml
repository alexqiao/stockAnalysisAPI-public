{% block extra_js %}
<script>
function getRecommendationClass(recommendation) {
    if (!recommendation) return 'hold';
    const rec = recommendation.toLowerCase();
    if (rec === 'buy') return 'buy';
    if (rec === 'sell') return 'sell';
    return 'hold';
}

function getSentimentClass(sentiment) {
    if (!sentiment) return 'neutral';
    const sent = sentiment.toLowerCase();
    if (sent === 'positive') return 'positive';
    if (sent === 'negative') return 'negative';
    return 'neutral';
}

function getRiskClass(risk) {
    if (!risk) return 'medium';
    const r = risk.toLowerCase();
    if (r === 'low') return 'low';
    if (r === 'high') return 'high';
    return 'medium';
}


function analyzeStock(symbol) {
    const resultDiv = document.getElementById('analysis-result');
    const loadingDiv = document.getElementById('analysis-loading');
    const titleDiv = document.getElementById('analysis-title');
    const contentDiv = document.getElementById('analysis-content');
    
    resultDiv.style.display = 'none';
    loadingDiv.style.display = 'block';
    
    const token = getCookie("access_token");
    const headers = {};
    if (token) {
        headers["Authorization"] = `Bearer ${token}`;
    }
    
    axios.get(`/api/analyze/${symbol}`, { headers: headers })
    .then(response => {
        const data = response.data;
        const analysis = data.analysis || {};
        const latestData = data.latest_data || {};

        // 设置主标题
        titleDiv.textContent = `${symbol} 分析报告 (更新于 ${data.analysis_date})`;
        
        // 生成关键点列表的HTML
        const keyPointsHtml = (analysis.key_points && analysis.key_points.length > 0)
            ? analysis.key_points.map(point => `<li><i class="fas fa-check-circle"></i><span>${point}</span></li>`).join('')
            : '<li>暂无关键点</li>';
            
        // 生成新闻列表的HTML
        const newsHtml = (data.news && data.news.length > 0)
            ? data.news.map(news => `<a href="${news.url || '#'}" target="_blank" class="list-group-item list-group-item-action">${news.title}</a>`).join('')
            : '<li class="list-group-item">暂无相关新闻</li>';

        // 这是全新的HTML结构
        contentDiv.innerHTML = `
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="summary-card ${getRecommendationClass(analysis.recommendation)}">
                        <div class="summary-card-title">投资建议</div>
                        <div class="summary-card-value">${analysis.recommendation?.toUpperCase() || 'N/A'}</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="summary-card ${getSentimentClass(analysis.overall_sentiment)}">
                        <div class="summary-card-title">总体评价</div>
                        <div class="summary-card-value">${analysis.overall_sentiment || 'N/A'}</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="summary-card ${getRiskClass(analysis.risk_level)}">
                        <div class="summary-card-title">风险水平</div>
                        <div class="summary-card-value">${analysis.risk_level?.toUpperCase() || 'N/A'}</div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">分析摘要</h5>
                            <p class="card-text">${analysis.summary || '暂无摘要'}</p>
                            <hr>

                            <h5 class="card-title mt-4"><i class="fas fa-key me-2"></i>关键点</h5>
                            <ul class="key-points-list">${keyPointsHtml}</ul>
                            <hr>
                            
                            <h5 class="card-title mt-4">技术分析</h5>
                            <p class="card-text">${analysis.technical_analysis || '暂无技术分析'}</p>
                            <hr>

                            <h5 class="card-title mt-4">分析理由</h5>
                            <p class="card-text">${analysis.reasoning || '暂无分析理由'}</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card data-card mb-4">
                        <div class="card-body">
                            <h5 class="card-title">最新日K数据</h5>
                            <ul>
                                <li><span>开盘价</span><strong>${latestData.open || 'N/A'}</strong></li>
                                <li><span>最高价</span><strong>${latestData.high || 'N/A'}</strong></li>
                                <li><span>最低价</span><strong>${latestData.low || 'N/A'}</strong></li>
                                <li><span>收盘价</span><strong>${latestData.close || 'N/A'}</strong></li>
                                <li><span>交易量</span><strong>${latestData.volume?.toLocaleString() || 'N/A'}</strong></li>
                            </ul>
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title"><i class="fas fa-newspaper me-2"></i>关键新闻</h5>
                            <div class="list-group list-group-flush">
                                ${newsHtml}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        `;
        
        resultDiv.style.display = 'block';
    })
    .catch(error => {
        const errorMessage = error.response?.data?.detail || '分析时发生未知错误，请稍后再试。';
        titleDiv.textContent = `${symbol} 分析报告`;
        contentDiv.innerHTML = `<div class="alert alert-danger">${errorMessage}</div>`;
        resultDiv.style.display = 'block';
    })
    .finally(() => {
        loadingDiv.style.display = 'none';
    });
}
function addStock() {
    const modal = new bootstrap.Modal(document.getElementById('addStockModal'));
    modal.show();
}

function getCookie(name) {
    const value = `; ${document.cookie}`;
    const parts = value.split(`; ${name}=`);
    if (parts.length === 2) {
        let cookieValue = parts.pop().split(';').shift();
        
        // 处理可能的引号包围
        if (cookieValue && cookieValue.startsWith('"') && cookieValue.endsWith('"')) {
            cookieValue = cookieValue.substring(1, cookieValue.length - 1);
        }
        
        // 移除 "Bearer " 前缀，如果存在的话
        if (cookieValue && cookieValue.startsWith('Bearer%20')) { // URL编码的空格
            cookieValue = cookieValue.substring(9); 
        } else if (cookieValue && cookieValue.startsWith('Bearer ')) {
            cookieValue = cookieValue.substring(7);
        }
        
        return cookieValue;
    }
    return null;
}

function toggleEmailNotifications() {
    const enabled = document.getElementById('emailNotifications').checked;
    // 直接发送请求，不需要token和headers
    axios.post('/api/toggle-notifications', {enabled: enabled})
    .then(response => {
        console.log('邮件通知设置已更新');
    })
    .catch(error => {
        alert('设置更新失败: ' + (error.response?.data?.error || '未知错误'));
        document.getElementById('emailNotifications').checked = !enabled;
    });
}

function deleteStock(symbol) {
    if (!confirm(`确定要删除股票 ${symbol} 吗？`)) {
        return;
    }
    
    // 获取cookie中的token
    const token = getCookie("access_token");
    
    // 创建包含token的请求头
    const headers = {};
    if (token) {
        headers["Authorization"] = token;
    }
    
    // 发送带有认证信息的请求
    axios.delete(`/api/unsubscribe/${symbol}`, { headers: headers })
    .then(response => {
        console.log('删除成功:', response.data);
        // 删除成功后重新加载页面
        location.reload();
    })
    .catch(error => {
        console.error('删除失败:', error.response?.data?.detail || '未知错误');
        alert('删除失败: ' + (error.response?.data?.detail || '未知错误'));
    });
}

function showUpdateEmailModal() {
    const modal = new bootstrap.Modal(document.getElementById('updateEmailModal'));
    modal.show();
}

function submitUpdateEmail() {
    const newEmail = document.getElementById('newEmail').value.trim();
    
    if (!newEmail) {
        alert('请输入邮箱地址');
        return;
    }
    
    // 获取cookie中的token
    const token = getCookie("access_token");
    
    // 创建包含token的请求头
    const headers = {};
    if (token) {
        headers["Authorization"] = `Bearer ${token}`;
        headers["Content-Type"] = "application/json";
    }
    
    // 发送邮箱更新请求
    axios.put('/api/users/me/email', { email: newEmail }, { headers: headers })
    .then(response => {
        alert('邮箱更新成功！');
        // 关闭模态框并重新加载页面
        const modal = bootstrap.Modal.getInstance(document.getElementById('updateEmailModal'));
        modal.hide();
        location.reload();
    })
    .catch(error => {
        const errorMessage = error.response?.data?.detail || '更新失败';
        alert('邮箱更新失败: ' + errorMessage);
    });
}

// 自动补全功能
let searchTimeout = null;

function searchSymbols(event) {
    const keyword = event.target.value.trim();
    const resultsContainer = document.getElementById('searchResults');
    
    // 清除之前的定时器
    if (searchTimeout) {
        clearTimeout(searchTimeout);
    }
    
    // 如果关键词为空，隐藏结果
    if (!keyword) {
        resultsContainer.style.display = 'none';
        return;
    }
    
    // 设置防抖，延迟300毫秒后执行搜索
    searchTimeout = setTimeout(() => {
        const token = getCookie("access_token");
        const headers = {};
        if (token) {
            headers["Authorization"] = `Bearer ${token}`;
        }
        
        axios.get(`/api/search-symbols?keyword=${encodeURIComponent(keyword)}`, { headers: headers })
            .then(response => {
                const results = response.data;
                displaySearchResults(results);
            })
            .catch(error => {
                console.error('搜索失败:', error);
                resultsContainer.style.display = 'none';
            });
    }, 300);
}

function displaySearchResults(results) {
    const resultsContainer = document.getElementById('searchResults');
    
    if (results.length === 0) {
        resultsContainer.style.display = 'none';
        return;
    }
    
    // 生成结果HTML
    const resultsHtml = results.map(result => `
        <div class="search-result-item" onclick="selectSymbol('${result.symbol}', '${result.name.replace(/'/g, "\\'")}')">
            <div class="symbol-text">${result.symbol}</div>
            <div class="name-text">${result.name}</div>
        </div>
    `).join('');
    
    resultsContainer.innerHTML = resultsHtml;
    resultsContainer.style.display = 'block';
}

function selectSymbol(symbol, name) {
    const searchInput = document.getElementById('stockSearchInput');
    const resultsContainer = document.getElementById('searchResults');
    
    // 填入选中的符号
    searchInput.value = symbol;
    
    // 隐藏结果容器
    resultsContainer.style.display = 'none';
    
    // 可选：显示选中的名称作为提示
    searchInput.setAttribute('title', name);
}

function submitAddStock() {
    const symbol = document.getElementById('stockSearchInput').value.trim().toUpperCase();
    if (!symbol) return;
    
    // 直接发送请求，不需要token和headers
    axios.post('/api/subscribe', {stock_symbol: symbol})
    .then(response => {
        location.reload();
    })
    .catch(error => {
        if (error.response?.status === 403) {
            // 对于403错误，显示服务器返回的详细错误信息
            alert(error.response?.data?.detail || '免费用户最多只能添加5支股票，请升级您的账户。');
        } else {
            // 对于其他错误，保持现有的通用错误提示
            alert('添加失败: ' + (error.response?.data?.error || '未知错误'));
        }
    });
}

// 点击模态框外部时隐藏搜索结果
document.addEventListener('click', function(event) {
    const searchContainer = document.querySelector('.search-container');
    const resultsContainer = document.getElementById('searchResults');
    
    if (searchContainer && !searchContainer.contains(event.target)) {
        resultsContainer.style.display = 'none';
    }
});
</script>
