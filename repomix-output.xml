<file path="app/web/templates/login.html">
{% extends "base.html" %}

{% block title %}登录 - Stock News Analyzer{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <div class="card">
            <div class="card-body">
                <h2 class="card-title text-center mb-4">用户登录</h2>
                
                {% if error %}
                <div class="alert alert-danger" role="alert">
                    {{ error }}
                </div>
                {% endif %}
                
                <form method="post" action="/login" id="loginForm">
                    <div class="mb-3">
                        <label for="username" class="form-label">用户名</label>
                        <input type="text" class="form-control" id="username" name="username" required>
                    </div>
                    
                    <div class="mb-3">
                        <label for="password" class="form-label">密码</label>
                        <input type="password" class="form-control" id="password" name="password" required>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100" id="loginBtn">
                        <span id="loginText">登录</span>
                        <span id="loadingSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                    </button>
                </form>
                
                <div class="text-center mt-3">
                    <p>还没有账户？ <a href="/register">立即注册</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('loginForm').addEventListener('submit', function(e) {
    const loginBtn = document.getElementById('loginBtn');
    const loginText = document.getElementById('loginText');
    const loadingSpinner = document.getElementById('loadingSpinner');
    
    // 禁用按钮并显示加载状态
    loginBtn.disabled = true;
    loginText.classList.add('d-none');
    loadingSpinner.classList.remove('d-none');
    
    // 表单会继续正常提交
});
</script>

<style>
.spinner-border-sm {
    width: 1rem;
    height: 1rem;
}
</style>
{% endblock %}
</file>

