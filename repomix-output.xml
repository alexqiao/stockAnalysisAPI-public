    }
    
    # 检查所有测试文件
    missing_files = []
    for name, path in test_files.items():
        if not os.path.exists(path):
            missing_files.append(path)
    
    if missing_files:
        print("❌ 以下测试文件缺失:")
        for file in missing_files:
            print(f"  - {file}")
        return False
    
    print("✅ 所有测试文件已找到")
    
    # 运行测试
    results = {}
    
    # 1. 运行单元测试
